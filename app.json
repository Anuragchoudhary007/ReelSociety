{
"expo": {
"name": "ReelSociety",
"slug": "ReelSociety",
"version": "1.0.0",

"orientation": "portrait",
"userInterfaceStyle": "dark",

"icon": "./assets/images/icon.png",
"scheme": "reelsociety",

"newArchEnabled": true,

"ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.anurag.reelsociety"
},

"android": {
  "package": "com.anurag.reelsociety",
  "versionCode": 1,

  "adaptiveIcon": {
    "foregroundImage": "./assets/images/icon.png",
    "backgroundColor": "#0B0B0B"
  },

  "navigationBar": {
    "backgroundColor": "#0B0B0B"
  },

  "edgeToEdgeEnabled": true
},

"web": {
  "output": "static",
  "favicon": "./assets/images/favicon.png"
},

"plugins": [
  "expo-router",

  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    }
  ],

  "expo-web-browser"
],

"experiments": {
  "typedRoutes": true,
  "reactCompiler": true
},

"extra": {
  "router": {},
  "eas": {
    "projectId": "f9cdbf9f-06bc-4814-a177-46cf229326fe"
  }
}

}
}